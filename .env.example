# Flask
FLASK_APP=run.py
FLASK_DEBUG=1
APP_ENV=development
SECRET_KEY=replace-with-a-long-random-value
# Keep false for plain HTTP localhost; set true when deployed behind HTTPS.
SESSION_COOKIE_SECURE=false
AUTO_CREATE_DATABASE=true

# Database
DATABASE_URL=sqlite:///safescroll.db

# Public URL used when building password-reset links
APP_BASE_URL=http://127.0.0.1:5000

# Optional Chrome Web Store listing URL
EXTENSION_INSTALL_URL=

# Extension REST API. Use exact origins, comma-separated; wildcards are not accepted.
# Example: chrome-extension://abcdefghijklmnopqrstuvwxyzabcdef
API_CORS_ORIGINS=
API_TOKEN_LIFETIME_DAYS=90
API_RATE_LIMIT_PER_MINUTE=120
API_RATE_LIMIT_WINDOW_SECONDS=60
PAIRING_TOKEN_LIFETIME_MINUTES=5
PAIRING_RATE_LIMIT_PER_MINUTE=10
PAIRING_EXCHANGE_RATE_LIMIT_PER_MINUTE=30

# Protected-mode PIN throttling (applies to browser and API attempts)
PIN_ATTEMPT_LIMIT=5
PIN_ATTEMPT_WINDOW_MINUTES=15
PIN_LOCKOUT_MINUTES=15

# SMTP (leave MAIL_SERVER empty to suppress network delivery during development)
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@safescroll.local
MAIL_SUPPRESS_SEND=false
