{
  "manifest_version": 3,
  "name": "SafeScroll",
  "description": "Synchronize SafeScroll modes and keep YouTube Shorts intentional.",
  "version": "1.0.0",
  "minimum_chrome_version": "120",
  "permissions": ["storage", "alarms", "tabs"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://safescroll.app/*",
    "https://www.youtube.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "SafeScroll",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1/*",
        "http://localhost/*",
        "https://safescroll.app/*"
      ],
      "js": ["pairing-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["youtube.js"],
      "run_at": "document_idle"
    }
  ]
}
